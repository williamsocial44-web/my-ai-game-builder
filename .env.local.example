# Copy this file to .env.local and fill in what you have, then restart `npm run dev`.
# The app degrades gracefully: features whose keys are missing are disabled, not broken.

# ── Required for AI game generation (both engines) ───────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Supabase (auth + cloud save of projects). Without these, games save to the
#    browser's localStorage and sign-in is disabled. ───────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Service role key — server-only. Needed for the Stripe webhook to grant premium
# and for the generations usage ledger. Never expose this to the browser.
SUPABASE_SERVICE_KEY=eyJ...

# ── fal.ai asset pipeline (sprites + premium character animation). ────────────
# Without FAL_KEY, /api/generate-asset returns a clean "not configured" response.
FAL_KEY=
# Optional model overrides if fal renames a model slug:
# FAL_BG_REMOVAL_MODEL=fal-ai/imageutils/rembg
# FAL_VIDEO_MODEL=fal-ai/wan-i2v

# ── Stripe (premium upgrade $49/mo). Without these, checkout + webhooks no-op. ─
STRIPE_SECRET_KEY=sk_live_or_test_...
STRIPE_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Optional: cheaper second engine (Ollama Cloud) for the PLAN + small EDITS.
#    Set OLLAMA_API_KEY to enable it; the pipeline falls back to Claude if absent.
# OLLAMA_API_KEY=
# OLLAMA_MODEL=gpt-oss:120b
# OLLAMA_BASE_URL=https://ollama.com

# ── Optional: pin the HTML generator's model/effort instead of auto-routing ───
# GENERATE_MODEL=        # e.g. claude-opus-4-8  (skips complexity routing)
# GENERATE_EFFORT=       # low | medium | high
# PLAN_MODEL=claude-haiku-4-5-20251001
